{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "French Pronunciation Studio",
  "version": "0.1.0",
  "identifier": "com.yotta.french-pronunciation-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "French Pronunciation Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
